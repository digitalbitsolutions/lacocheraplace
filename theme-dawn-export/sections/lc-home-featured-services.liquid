{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lc-home-services__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.2rem;
    margin-bottom: 1.6rem;
  }

  .lc-home-services__sub {
    margin: 0.4rem 0 0;
    color: rgba(var(--color-foreground), 0.7);
  }

  .lc-home-services__track {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .lc-home-services__card {
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 1.2rem;
    background: rgb(var(--color-background));
    overflow: hidden;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .lc-home-services__image-wrap {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .lc-home-services__badge {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    z-index: 1;
    padding: 0.2rem 0.8rem;
    border-radius: 99rem;
    font-size: 1.1rem;
    color: #fff;
    background: #0f4cbd;
  }

  .lc-home-services__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lc-home-services__body {
    padding: 1rem;
    display: grid;
    gap: 0.5rem;
  }

  .lc-home-services__title {
    margin: 0;
    font-size: 1.7rem;
    line-height: 1.3;
  }

  .lc-home-services__price {
    margin: 0;
    color: #0f4cbd;
    font-weight: 700;
    font-size: 1.6rem;
  }

  .lc-home-services__meta {
    margin: 0;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.76);
  }

  @media screen and (min-width: 750px) {
    .lc-home-services__track {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .lc-home-services__track {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1.2rem;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="lc-home-services__head">
      <div>
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
        <p class="lc-home-services__sub">{{ section.settings.subtitle }}</p>
      </div>
      {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </div>
    <div class="lc-home-services__track">
      {%- for block in section.blocks -%}
        <article class="lc-home-services__card" {{ block.shopify_attributes }}>
          <a class="lc-home-services__image-wrap" href="{{ block.settings.link | default: '#' }}">
            {%- if block.settings.badge != blank -%}
              <span class="lc-home-services__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 960
                | image_tag:
                  class: 'lc-home-services__image',
                  loading: 'lazy',
                  alt: block.settings.title
              }}
            {%- endif -%}
          </a>
          <div class="lc-home-services__body">
            <h3 class="lc-home-services__title"><a href="{{ block.settings.link | default: '#' }}">{{ block.settings.title }}</a></h3>
            <p class="lc-home-services__price">{{ block.settings.price_text }}</p>
            <p class="lc-home-services__meta">{{ block.settings.rating_text }} | {{ block.settings.city }} | {{ block.settings.provider }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LCP Home Services",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Servicios destacados" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Los servicios mas demandados por nuestros usuarios" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Ver todos los servicios" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 8 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 20 }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Popular" },
        { "type": "text", "id": "title", "label": "Title", "default": "Servicio" },
        { "type": "text", "id": "price_text", "label": "Price text", "default": "Desde 49EUR" },
        { "type": "text", "id": "rating_text", "label": "Rating", "default": "4.8 (120)" },
        { "type": "text", "id": "city", "label": "City", "default": "Barcelona" },
        { "type": "text", "id": "provider", "label": "Provider", "default": "La Cochera Place" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "LCP Home Services" }
  ]
}
{% endschema %}
