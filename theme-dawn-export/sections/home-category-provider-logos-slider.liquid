{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.2rem;
    margin-bottom: 1.8rem;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__sub {
    margin: 0.4rem 0 0;
    color: rgba(var(--color-foreground), 0.72);
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__viewport {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc(100% - 3.2rem);
    gap: 1.2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__viewport::-webkit-scrollbar {
    display: none;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__card {
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 1.4rem;
    background: rgb(var(--color-background));
    overflow: hidden;
    scroll-snap-align: start;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__media-wrap {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__badge {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 1;
    width: 5.2rem;
    height: 5.2rem;
    border-radius: 99rem;
    border: 0.25rem solid #fff;
    background: #111;
    color: #fff;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 0.4rem;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__body {
    padding: 1.2rem;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__title {
    margin: 0 0 0.55rem;
    font-size: 2.2rem;
    line-height: 1.25;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__meta {
    margin: 0 0 0.8rem;
    font-size: 1.25rem;
    color: rgba(var(--color-foreground), 0.78);
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__chips {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__chip {
    border-radius: 99rem;
    padding: 0.25rem 0.75rem;
    font-size: 1.1rem;
    background: rgba(26, 60, 141, 0.08);
    color: rgba(26, 60, 141, 0.9);
    line-height: 1.2;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__controls {
    margin-top: 1.4rem;
    display: flex;
    justify-content: center;
    gap: 0.8rem;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__btn {
    width: 4.2rem;
    height: 4.2rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.24);
    border-radius: 99rem;
    background: rgb(var(--color-background));
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .lcp-workshops-{{ section.id }} .lcp-workshops__btn[disabled] {
    opacity: 0.4;
  }

  @media screen and (min-width: 750px) {
    .lcp-workshops-{{ section.id }} .lcp-workshops__viewport {
      grid-auto-columns: calc((100% - 1.2rem) / 2);
    }
  }

  @media screen and (min-width: 990px) {
    .lcp-workshops-{{ section.id }} .lcp-workshops__viewport {
      grid-auto-columns: calc((100% - (1.2rem * 3)) / 4);
    }
  }
{%- endstyle -%}

<section class="lcp-workshops-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="lcp-workshops__head">
      <div>
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
        <p class="lcp-workshops__sub">{{ section.settings.subtitle }}</p>
      </div>
      {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </div>

    <div class="lcp-workshops__viewport" data-slider-track>
      {%- for block in section.blocks -%}
        <article class="lcp-workshops__card" {{ block.shopify_attributes }}>
          <a class="lcp-workshops__media-wrap" href="{{ block.settings.link | default: '#' }}">
            {%- assign workshop_image = block.settings.image | default: block.settings.logo -%}
            {%- if workshop_image != blank -%}
              {{
                workshop_image
                | image_url: width: 960
                | image_tag:
                  class: 'lcp-workshops__media',
                  loading: 'lazy',
                  alt: block.settings.provider_name
              }}
            {%- endif -%}
            {%- assign badge_text = block.settings.badge_text | default: block.settings.category -%}
            {%- if badge_text != blank -%}
              <span class="lcp-workshops__badge">{{ badge_text }}</span>
            {%- endif -%}
          </a>
          <div class="lcp-workshops__body">
            <h3 class="lcp-workshops__title"><a href="{{ block.settings.link | default: '#' }}">{{ block.settings.provider_name }}</a></h3>
            <p class="lcp-workshops__meta">{{ block.settings.rating_text | default: '4.8 (96)' }} | {{ block.settings.city | default: 'Barcelona' }}</p>
            <p class="lcp-workshops__chips">
              {%- if block.settings.chip_1 != blank -%}<span class="lcp-workshops__chip">{{ block.settings.chip_1 }}</span>{%- elsif block.settings.category != blank -%}<span class="lcp-workshops__chip">{{ block.settings.category }}</span>{%- endif -%}
              {%- if block.settings.chip_2 != blank -%}<span class="lcp-workshops__chip">{{ block.settings.chip_2 }}</span>{%- endif -%}
              {%- if block.settings.chip_3 != blank -%}<span class="lcp-workshops__chip">{{ block.settings.chip_3 }}</span>{%- endif -%}
            </p>
          </div>
        </article>
      {%- endfor -%}
    </div>

    <div class="lcp-workshops__controls">
      <button type="button" class="lcp-workshops__btn" aria-label="{{ 'general.slider.previous_slide' | t }}" data-slider-prev>
        <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
      </button>
      <button type="button" class="lcp-workshops__btn" aria-label="{{ 'general.slider.next_slide' | t }}" data-slider-next>
        <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
      </button>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector('.lcp-workshops-{{ section.id }}');
    if (!root) return;
    const track = root.querySelector('[data-slider-track]');
    const prev = root.querySelector('[data-slider-prev]');
    const next = root.querySelector('[data-slider-next]');
    if (!track || !prev || !next) return;

    const update = () => {
      const max = track.scrollWidth - track.clientWidth;
      prev.disabled = track.scrollLeft <= 0;
      next.disabled = track.scrollLeft >= max - 2;
    };

    const slide = (dir) => {
      const amount = Math.max(220, Math.round(track.clientWidth * 0.9));
      track.scrollBy({ left: amount * dir, behavior: 'smooth' });
    };

    prev.addEventListener('click', () => slide(-1));
    next.addEventListener('click', () => slide(1));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  })();
</script>

{% schema %}
{
  "name": "Featured Provider Logos",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Talleres destacados" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Profesionales verificados cerca de ti" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Ver todos los talleres" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 20 }
  ],
  "blocks": [
    {
      "type": "provider_logo",
      "name": "Workshop card",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Legacy logo/image (compat)" },
        { "type": "image_picker", "id": "image", "label": "Card image" },
        { "type": "text", "id": "category", "label": "Legacy category (compat)", "default": "Mecánica" },
        { "type": "text", "id": "badge_text", "label": "Badge text", "default": "MEC AUTO" },
        { "type": "text", "id": "provider_name", "label": "Provider name", "default": "MecAuto Services" },
        { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.8 (132)" },
        { "type": "text", "id": "city", "label": "City", "default": "Hospitalet de Llobregat" },
        { "type": "text", "id": "chip_1", "label": "Chip 1", "default": "Mecánica" },
        { "type": "text", "id": "chip_2", "label": "Chip 2", "default": "Frenos" },
        { "type": "text", "id": "chip_3", "label": "Chip 3", "default": "Diagnostico" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Featured Provider Logos"
    }
  ]
}
{% endschema %}
