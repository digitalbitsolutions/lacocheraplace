{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- if section.settings.enable_stitch_cards -%}
    .multicolumn--stitch-{{ section.id }} {
      overflow-x: clip;
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-list {
      row-gap: 1.8rem;
      column-gap: 1.6rem;
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-card {
      border: 0.1rem solid rgba(var(--color-foreground), 0.08);
      border-radius: 1.2rem;
      overflow: hidden;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      background: rgb(var(--color-background));
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-card:hover {
      transform: translateY(-0.2rem);
      box-shadow: 0 1rem 2.6rem rgba(var(--color-foreground), 0.11);
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-card__image-wrapper {
      margin-bottom: 0;
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-card__info {
      padding: 1.2rem 1.2rem 1.3rem;
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-card__info > h3 {
      margin: 0 0 0.6rem;
      font-size: 1.5rem;
      line-height: 1.35;
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-card__info .rte {
      display: none;
    }

    .multicolumn--stitch-{{ section.id }} .multicolumn-card .link.animate-arrow {
      margin-top: 0.9rem;
      display: inline-flex;
      align-items: center;
      font-size: 1.25rem;
      font-weight: 600;
    }

    @media screen and (max-width: 749px) {
      .multicolumn--stitch-{{ section.id }} .multicolumn-list:not(.slider) {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.2rem;
        padding-left: 1rem;
        padding-right: 1rem;
      }

      .multicolumn--stitch-{{ section.id }} .multicolumn-list:not(.slider) .multicolumn-list__item {
        width: auto;
        max-width: none;
        min-width: 0;
        margin: 0;
      }

      .multicolumn--stitch-{{ section.id }} .multicolumn-card__info {
        padding: 1rem;
      }

      .multicolumn--stitch-{{ section.id }} .multicolumn-card__info > h3 {
        font-size: 1.35rem;
      }
    }
  {%- endif -%}

  {%- if request.page_type == 'page' and page and page.handle == 'como-funciona' and section.id == 'multicolumn_steps' -%}
    .multicolumn--como-funciona .multicolumn-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 2rem;
      row-gap: 2rem;
    }

    .multicolumn--como-funciona .multicolumn-list__item {
      width: auto;
      max-width: none;
      margin: 0;
    }

    @media screen and (min-width: 990px) {
      .multicolumn--como-funciona .multicolumn-list {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }

    .multicolumn--como-funciona .multicolumn__title .title {
      margin-bottom: 0.8rem;
      font-size: clamp(2.8rem, 2.3rem + 0.9vw, 3.8rem);
      letter-spacing: -0.01em;
    }

    .multicolumn--como-funciona .multicolumn-card {
      border: 0.1rem solid rgba(var(--color-foreground), 0.12);
      border-radius: 0.8rem;
      background: rgb(var(--color-background));
      box-shadow: none;
      overflow: hidden;
    }

    .multicolumn--como-funciona .multicolumn-card__image-wrapper {
      margin-bottom: 0;
    }

    .multicolumn--como-funciona .multicolumn-card__info {
      padding: 1.6rem 2rem 1.8rem;
    }

    .multicolumn--como-funciona .multicolumn-card__info > h3 {
      margin: 0 0 1.2rem;
      font-size: 2.8rem;
      line-height: 1.1;
      color: rgba(40, 92, 203, 1);
    }

    .multicolumn--como-funciona .multicolumn-card__info .rte {
      color: rgba(var(--color-foreground), 0.78);
    }

    .multicolumn--como-funciona .multicolumn-card__info .rte p {
      margin: 0 0 1rem;
      font-size: 1.55rem;
      line-height: 1.55;
    }

    .multicolumn--como-funciona .multicolumn-card__info .rte p:first-child {
      margin-bottom: 1rem;
      font-size: 3rem;
      line-height: 1.1;
      color: rgb(var(--color-foreground));
      letter-spacing: -0.01em;
    }

    @media screen and (max-width: 989px) {
      .multicolumn--como-funciona .multicolumn-card__info .rte p:first-child {
        font-size: 2.4rem;
      }
    }
  {%- endif -%}

  {%- if section.id contains 'provider_benefits' -%}
    .multicolumn--provider-benefits {
      margin-top: -17.2rem;
      margin-bottom: 2.4rem;
      position: relative;
      z-index: 4;
      background: transparent;
    }

    .multicolumn--provider-benefits .page-width {
      max-width: 112rem;
      background: linear-gradient(90deg, rgba(7, 12, 22, 0.84), rgba(7, 12, 22, 0.7));
      border-radius: 0;
      padding-top: 0;
      padding-bottom: 1rem;
      padding-left: 1.4rem;
      padding-right: 1.4rem;
      width: min(100%, 112rem);
      margin-left: auto;
      margin-right: auto;
    }

    .multicolumn--provider-benefits .multicolumn-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
    }

    .multicolumn--provider-benefits .multicolumn-list__item {
      width: auto;
      max-width: none;
      margin: 0;
      border-right: 0.1rem solid rgba(255, 255, 255, 0.18);
    }

    .multicolumn--provider-benefits .multicolumn-list__item:last-child {
      border-right: 0;
    }

    .multicolumn--provider-benefits .multicolumn-card {
      background: transparent;
      border: 0;
      box-shadow: none;
    }

    .multicolumn--provider-benefits .multicolumn-card__info {
      padding: 0.5rem 1.2rem 0.5rem 1.2rem;
    }

    .multicolumn--provider-benefits .provider-benefit-icon {
      display: inline-flex;
      width: 2.8rem;
      height: 2.8rem;
      color: #1f5fe0;
      margin-bottom: 0.7rem;
    }

    .multicolumn--provider-benefits .provider-benefit-icon svg,
    .multicolumn--provider-benefits .provider-benefit-icon svg * {
      width: 100%;
      height: 100%;
      fill: currentColor !important;
      stroke: currentColor !important;
    }

    .multicolumn--provider-benefits .multicolumn-card__info > h3,
    .multicolumn--provider-benefits .multicolumn-card__info .rte,
    .multicolumn--provider-benefits .multicolumn-card__info .rte p {
      color: rgba(255, 255, 255, 0.92);
    }

    .multicolumn--provider-benefits .multicolumn-card__info > h3 {
      margin: 0 0 0.6rem;
      font-size: 1.7rem;
      line-height: 1.25;
      letter-spacing: -0.01em;
      font-weight: 600;
    }

    .multicolumn--provider-benefits .multicolumn-card__info .rte p {
      margin: 0;
      font-size: 1.25rem;
      line-height: 1.45;
      color: rgba(255, 255, 255, 0.8);
    }

    @media screen and (max-width: 989px) {
      .multicolumn--provider-benefits {
        margin-top: -7rem;
        margin-bottom: 2.4rem;
      }

      .multicolumn--provider-benefits .page-width {
        width: calc(100% - 2.4rem);
        margin-left: auto;
        margin-right: auto;
        padding-left: 1.4rem;
        padding-right: 1.4rem;
      }

      .multicolumn--provider-benefits .multicolumn-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.4rem 1.8rem;
      }

      .multicolumn--provider-benefits .multicolumn-list__item {
        border-right: 0;
      }

      .multicolumn--provider-benefits .multicolumn-card__info {
        padding-left: 0;
        padding-right: 0;
      }

      .multicolumn--provider-benefits .provider-benefit-icon {
        width: 2.5rem;
        height: 2.5rem;
      }

      .multicolumn--provider-benefits .multicolumn-card__info > h3 {
        font-size: 1.6rem;
      }

      .multicolumn--provider-benefits .multicolumn-card__info .rte p {
        font-size: 1.2rem;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  assign is_como_funciona_override = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="multicolumn multicolumn--stitch-{{ section.id }}{% if request.page_type == 'page' and page and page.handle == 'como-funciona' and section.id == 'multicolumn_steps' %} multicolumn--como-funciona{% endif %}{% if section.id contains 'provider_benefits' %} multicolumn--provider-benefits{% endif %} color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin multicolumn__title">
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
        {%- if section.settings.button_label != blank and show_mobile_slider -%}
          <a href="{{ section.settings.button_link }}" class="link underlined-link large-up-hide">
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}
    <slider-component class="slider-mobile-gutter">
      <ul
        class="multicolumn-list contains-content-container grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- liquid
          assign highest_ratio = 0
          for block in section.blocks
            if block.settings.image.aspect_ratio > highest_ratio
              assign highest_ratio = block.settings.image.aspect_ratio
            endif
          endfor
        -%}
        {%- for block in section.blocks -%}
          {%- assign empty_column = '' -%}
          {%- assign custom_home_image_asset = block.settings.custom_asset_image | strip -%}
          {%- if block.settings.image == blank
            and custom_home_image_asset == blank
            and block.settings.title == blank
            and block.settings.text == blank
            and block.settings.link_label == blank
          -%}
            {%- assign empty_column = ' multicolumn-list__item--empty' -%}
          {%- endif -%}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="multicolumn-list__item grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}{{ empty_column }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="multicolumn-card content-container full-unstyled-link">
            {% else %}
              <div class="multicolumn-card content-container">
            {% endif %}
              {%- if block.settings.image != blank or custom_home_image_asset != blank -%}
                {% if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' %}
                  {% assign spaced_image = true %}
                {% endif %}
                <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' or spaced_image %} multicolumn-card-spacing{% endif %}">
                  <div
                    class="media media--transparent media--{{ section.settings.image_ratio }}"
                    {% if section.settings.image_ratio == 'adapt' %}
                      style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                    {% endif %}
                  >
                    {%- liquid
                      assign number_of_columns = section.settings.columns_desktop
                      assign number_of_columns_mobile = section.settings.columns_mobile
                      assign grid_space_desktop = number_of_columns | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                      if section.settings.image_width == 'half'
                        assign image_width = 0.5
                      elsif section.settings.image_width == 'third'
                        assign image_width = 0.33
                      else
                        assign image_width = 1
                      endif
                    -%}
                    {% capture sizes %}
                      (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} /  {{ number_of_columns }}),
                      (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                      (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                      calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                    {% endcapture %}
                    {%- if custom_home_image_asset != blank -%}
                      <img
                        src="{{ custom_home_image_asset | asset_url }}"
                        alt="{{ block.settings.title | escape }}"
                        loading="lazy"
                        class="multicolumn-card__image"
                      >
                    {%- else -%}
                      {{
                        block.settings.image
                        | image_url: width: 3200
                        | image_tag:
                          widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                          sizes: sizes,
                          class: 'multicolumn-card__image'
                      }}
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
              <div class="multicolumn-card__info">
                {%- if section.id contains 'provider_benefits' -%}
                  {%- liquid
                    assign benefit_icon = 'icon-account.svg'
                    case forloop.index
                      when 1
                        assign benefit_icon = 'icon-account.svg'
                      when 2
                        assign benefit_icon = 'icon-lightning-bolt.svg'
                      when 3
                        assign benefit_icon = 'icon-chat-bubble.svg'
                      when 4
                        assign benefit_icon = 'icon-padlock.svg'
                    endcase
                  -%}
                  <span class="provider-benefit-icon" aria-hidden="true">
                    {{ benefit_icon | inline_asset_content }}
                  </span>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="inline-richtext">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.link_label != blank and block.settings.link == blank -%}
                  <a
                    class="link animate-arrow"
                    {% if block.settings.link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                  >
                    {{- block.settings.link_label | escape -}}
                    <span class="svg-wrapper"
                      ><span class="icon-wrap">&nbsp;{{ 'icon-arrow.svg' | inline_asset_content }}</span></span
                    >
                  </a>
                {%- elsif block.settings.link_label != blank and block.settings.link != blank -%}
                  <span class="link animate-arrow">
                    {{- block.settings.link_label | escape -}}
                    <span class="svg-wrapper"
                      ><span class="icon-wrap">&nbsp;{{ 'icon-arrow.svg' | inline_asset_content }}</span></span
                    >
                  </span>
                {%- endif -%}
              </div>
            {% if block.settings.link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider -%}
        <div class="slider-buttons large-up-hide">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
        </div>
      {%- endif -%}
    </slider-component>
    <div class="center{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
      {%- if section.settings.button_label != blank -%}
        <a
          class="button button--primary"
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.multicolumn.settings.title.default",
      "label": "t:sections.multicolumn.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_image.content"
    },    
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.multicolumn.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.multicolumn.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.multicolumn.settings.image_width.options__3.label"
        }
      ],
      "default": "full",
      "label": "t:sections.multicolumn.settings.image_width.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.multicolumn.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.multicolumn.settings.image_ratio.options__3.label"
        },
        {
          "value": "circle",
          "label": "t:sections.multicolumn.settings.image_ratio.options__4.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.multicolumn.settings.image_ratio.label"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_button.content"
    },    
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.multicolumn.settings.button_label.default",
      "label": "t:sections.multicolumn.settings.button_label.label", 
      "info": "t:sections.multicolumn.settings.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.multicolumn.settings.button_link.label"
    },    
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_layout.content"
    },     
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.multicolumn.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.multicolumn.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.multicolumn.settings.column_alignment.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.multicolumn.settings.column_alignment.label"
    },
    {
      "type": "select",
      "id": "background_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.multicolumn.settings.background_style.options__1.label"
        },
        {
          "value": "primary",
          "label": "t:sections.multicolumn.settings.background_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.multicolumn.settings.background_style.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },    
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1",
      "label": "t:sections.multicolumn.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
