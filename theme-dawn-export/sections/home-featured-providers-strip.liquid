{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-providers-strip-{{ section.id }} .home-providers-strip__title {
    margin: 0 0 2rem;
  }

  .home-providers-strip-{{ section.id }} .home-providers-strip__grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .home-providers-strip-{{ section.id }} .home-providers-strip__card {
    display: grid;
    grid-template-columns: 5.2rem 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    background: rgb(var(--color-background));
    box-shadow: 0 0.6rem 1.6rem rgba(var(--color-foreground), 0.08);
  }

  .home-providers-strip-{{ section.id }} .home-providers-strip__logo {
    width: 5.2rem;
    height: 5.2rem;
    border-radius: 0.8rem;
    object-fit: cover;
    background: rgba(var(--color-foreground), 0.06);
  }

  .home-providers-strip-{{ section.id }} .home-providers-strip__name {
    margin: 0 0 0.2rem;
    font-size: 1.45rem;
    line-height: 1.35;
  }

  .home-providers-strip-{{ section.id }} .home-providers-strip__meta {
    margin: 0;
    font-size: 1.25rem;
    color: rgba(var(--color-foreground), 0.74);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .home-providers-strip-{{ section.id }} .home-providers-strip__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0 0.8rem;
    border-radius: 999px;
    font-size: 1.1rem;
    background: rgba(15, 76, 189, 0.11);
    color: #0f4cbd;
    font-weight: 700;
  }

  @media screen and (min-width: 750px) {
    .home-providers-strip-{{ section.id }} .home-providers-strip__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

<section class="home-providers-strip-{{ section.id }} color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="home-providers-strip__title {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
    {%- endif -%}

    <ul class="home-providers-strip__grid" role="list">
      {%- assign source_collection = section.settings.source_collection -%}
      {%- assign dynamic_limit = section.settings.dynamic_limit | default: 6 -%}
      {%- assign provider_profiles = shop.metaobjects.provider_profile.values -%}
      {%- if source_collection != blank and source_collection.products_count > 0 -%}
        {%- for product in source_collection.products limit: dynamic_limit -%}
          {%- assign rating_value = product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value | default: '' -%}
          {%- assign rating_count = product.metafields.reviews.rating_count | default: '' -%}
          {%- assign provider_logo_url = '' -%}
          {%- if section.settings.use_provider_profile_logo and provider_profiles != blank and product.vendor != blank -%}
            {%- for provider_profile in provider_profiles -%}
              {%- assign profile_vendor_name = provider_profile.catalog_vendor_name.value | default: provider_profile.display_name.value | default: '' -%}
              {%- if profile_vendor_name == product.vendor -%}
                {%- assign provider_logo_url = provider_profile.logo_source_url.value | default: '' -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          <li>
            <a class="home-providers-strip__card" href="{{ product.url }}">
              {%- if provider_logo_url != blank -%}
                <img
                  class="home-providers-strip__logo"
                  src="{{ provider_logo_url | escape }}"
                  alt="{{ product.vendor | default: product.title | escape }}"
                  loading="lazy"
                  width="180"
                  height="180"
                >
              {%- elsif product.featured_image != blank -%}
                {{
                  product.featured_image
                  | image_url: width: 180
                  | image_tag:
                    widths: '80, 120, 160, 180',
                    class: 'home-providers-strip__logo',
                    alt: product.title
                }}
              {%- else -%}
                <span class="home-providers-strip__logo"></span>
              {%- endif -%}

              <span>
                <p class="home-providers-strip__name">{{ product.title }}</p>
                <p class="home-providers-strip__meta">
                  <span>
                    {%- if rating_value != blank and rating_count != blank -%}
                      {{ rating_value }}/5
                    {%- elsif rating_value != blank -%}
                      {{ rating_value }}/5
                    {%- else -%}
                      {{ section.settings.fallback_rating }}
                    {%- endif -%}
                  </span>
                  <span aria-hidden="true">|</span>
                  <span class="home-providers-strip__badge">
                    {%- if product.available -%}
                      {{ section.settings.available_tag }}
                    {%- else -%}
                      {{ section.settings.unavailable_tag }}
                    {%- endif -%}
                  </span>
                </p>
              </span>
            </a>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- assign block_vendor_name = block.settings.name | strip -%}
          {%- assign provider_logo_url = '' -%}
          {%- assign provider_gallery_image = blank -%}
          {%- assign provider_reference_product = block.settings.provider_product -%}
          {%- assign mapped_product_handle = '' -%}

          {%- case block.settings.name -%}
            {%- when 'Kit limpieza interior premium' -%}
              {%- assign mapped_product_handle = 'cueros-aros-la-cochera-place' -%}
            {%- when 'Cera y sellador de pintura' -%}
              {%- assign mapped_product_handle = 'pulido-correccion-detail-lab-bcn' -%}
            {%- when 'Ambientadores y fragancias' -%}
              {%- assign mapped_product_handle = 'lavado-ecologico-gracia-auto-spa' -%}
            {%- when 'Limpiallantas y brillo neumatico' -%}
              {%- assign mapped_product_handle = 'detailing-esencial-barcelona-wash-hub' -%}
            {%- when 'Toallas microfibra detailing' -%}
              {%- assign mapped_product_handle = 'reparacion-paragolpes-sants-wrap-studio' -%}
            {%- when 'Accesorios interior y confort' -%}
              {%- assign mapped_product_handle = 'asistencia-bateria-costa-garage-express' -%}
          {%- endcase -%}
          {%- if block.settings.link contains '/collections/vendors?q=' -%}
            {%- assign vendor_query = block.settings.link | split: 'q=' | last | split: '&' | first -%}
            {%- assign block_vendor_name = vendor_query | replace: '+', ' ' | url_decode | strip -%}
          {%- endif -%}
          {%- if mapped_product_handle != blank and all_products[mapped_product_handle] and all_products[mapped_product_handle].featured_image != blank -%}
            {%- assign provider_gallery_image = all_products[mapped_product_handle].featured_image -%}
          {%- elsif provider_reference_product != blank and provider_reference_product.featured_image != blank -%}
            {%- assign provider_gallery_image = provider_reference_product.featured_image -%}
          {%- elsif block_vendor_name != blank and collections.all != blank -%}
            {%- for candidate_product in collections.all.products -%}
              {%- if candidate_product.vendor == block_vendor_name -%}
                {%- assign last_media_with_image = blank -%}
                {%- for media_item in candidate_product.media -%}
                  {%- if media_item.media_type == 'image' and media_item.preview_image != blank -%}
                    {%- assign last_media_with_image = media_item.preview_image -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if last_media_with_image != blank -%}
                  {%- assign provider_gallery_image = last_media_with_image -%}
                {%- elsif candidate_product.featured_image != blank -%}
                  {%- assign provider_gallery_image = candidate_product.featured_image -%}
                {%- endif -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if section.settings.use_provider_profile_logo and provider_profiles != blank and block_vendor_name != blank -%}
            {%- for provider_profile in provider_profiles -%}
              {%- assign profile_vendor_name = provider_profile.catalog_vendor_name.value | default: provider_profile.display_name.value | default: '' -%}
              {%- if profile_vendor_name == block_vendor_name -%}
                {%- assign provider_logo_url = provider_profile.logo_source_url.value | default: '' -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          <li {{ block.shopify_attributes }}>
            <a
              class="home-providers-strip__card"
              {% if block.settings.link != blank %}
                href="{{ block.settings.link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
            >
              {%- if provider_logo_url != blank -%}
                <img
                  class="home-providers-strip__logo"
                  src="{{ provider_logo_url | escape }}"
                  alt="{{ block_vendor_name | default: block.settings.name | escape }}"
                  loading="lazy"
                  width="180"
                  height="180"
                >
              {%- elsif provider_gallery_image != blank -%}
                {{
                  provider_gallery_image
                  | image_url: width: 180
                  | image_tag:
                    widths: '80, 120, 160, 180',
                    class: 'home-providers-strip__logo',
                    alt: block_vendor_name
                }}
              {%- elsif block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 180
                  | image_tag:
                    widths: '80, 120, 160, 180',
                    class: 'home-providers-strip__logo',
                    alt: block.settings.name
                }}
              {%- else -%}
                <span class="home-providers-strip__logo"></span>
              {%- endif -%}

              <span>
                <p class="home-providers-strip__name">{{ block.settings.name }}</p>
                <p class="home-providers-strip__meta">
                  <span>{{ block.settings.rating }}</span>
                  <span aria-hidden="true">|</span>
                  <span class="home-providers-strip__badge">{{ block.settings.tag }}</span>
                </p>
              </span>
            </a>
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Home Featured Providers",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Talleres destacados" },
    { "type": "checkbox", "id": "use_provider_profile_logo", "label": "Use provider profile logo when available", "default": true },
    { "type": "collection", "id": "source_collection", "label": "Dynamic source collection" },
    { "type": "range", "id": "dynamic_limit", "min": 3, "max": 12, "step": 1, "default": 6, "label": "Dynamic items limit" },
    { "type": "text", "id": "fallback_rating", "label": "Fallback rating", "default": "4.8/5" },
    { "type": "text", "id": "available_tag", "label": "Available tag", "default": "Disponible" },
    { "type": "text", "id": "unavailable_tag", "label": "Unavailable tag", "default": "No disponible" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 12 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 28 }
  ],
  "blocks": [
    {
      "type": "provider",
      "name": "Provider",
      "limit": 9,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo" },
        { "type": "product", "id": "provider_product", "label": "Provider reference product (uses featured image)" },
        { "type": "text", "id": "name", "label": "Name", "default": "La Cochera Place" },
        { "type": "text", "id": "rating", "label": "Rating text", "default": "4.8/5" },
        { "type": "text", "id": "tag", "label": "Tag", "default": "Verificado" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Featured Providers",
      "blocks": [
        { "type": "provider", "settings": { "name": "La Cochera Place", "rating": "4.8/5", "tag": "Verificado" } },
        { "type": "provider", "settings": { "name": "Workshop", "rating": "4.8/5", "tag": "Verificado" } },
        { "type": "provider", "settings": { "name": "Warmtless", "rating": "4.8/5", "tag": "Verificado" } }
      ]
    }
  ]
}
{% endschema %}
