{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .home-how-steps-{{ section.id }} {
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-how-steps-{{ section.id }} .home-how-steps__heading {
    margin: 0;
    text-align: center;
    font-size: clamp(3.8rem, 5vw, 5.6rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__eyebrow {
    margin: 0 0 1.6rem;
    text-align: center;
    font-size: 1.6rem;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1d5bd7;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__heading-accent {
    width: 4rem;
    height: 0.4rem;
    margin: 1.4rem auto 1.8rem;
    border-radius: 999px;
    background: #1d5bd7;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__subtitle {
    margin: 0 auto 3.2rem;
    max-width: 54rem;
    text-align: center;
    font-size: 1.8rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.72);
  }

  .home-how-steps-{{ section.id }} .home-how-steps__grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 3rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__item {
    text-align: center;
    position: relative;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__stephead {
    display: none;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__stepbubble {
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #1d5bd7;
    color: #fff;
    font-size: 1.8rem;
    font-weight: 700;
    box-shadow: none;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__stepline {
    display: none;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__media {
    position: relative;
    margin: 0 auto 4.8rem;
    max-width: 30rem;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 12;
    object-fit: cover;
    border-radius: 2.2rem;
    box-shadow: 0 1.2rem 3rem rgba(17, 32, 70, 0.12);
  }

  .home-how-steps-{{ section.id }} .home-how-steps__image-placeholder {
    width: 100%;
    aspect-ratio: 16 / 12;
    border-radius: 2.2rem;
    background: linear-gradient(135deg, rgba(29, 91, 215, 0.12), rgba(29, 91, 215, 0.04));
    box-shadow: 0 1.2rem 3rem rgba(17, 32, 70, 0.08);
  }

  .home-how-steps-{{ section.id }} .home-how-steps__icon {
    position: absolute;
    left: 50%;
    bottom: -3.2rem;
    transform: translateX(-50%);
    width: 7.2rem;
    height: 7.2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    color: #0f4cbd;
    border: 0.1rem solid rgba(15, 76, 189, 0.12);
    box-shadow: 0 1rem 2.4rem rgba(20, 37, 77, 0.14);
  }

  .home-how-steps-{{ section.id }} .home-how-steps__icon svg {
    width: 3.4rem;
    height: 3.4rem;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__title {
    margin: 0;
    font-size: 1.8rem;
    line-height: 1.2;
    font-weight: 700;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__title-accent {
    width: 4.2rem;
    height: 0.3rem;
    margin: 1.2rem auto 1.4rem;
    border-radius: 999px;
    background: #1d5bd7;
  }

  .home-how-steps-{{ section.id }} .home-how-steps__text {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.72);
  }

  @media screen and (min-width: 750px) {
    .home-how-steps-{{ section.id }} .home-how-steps__stephead {
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3.6rem;
      z-index: 2;
    }

    .home-how-steps-{{ section.id }} .home-how-steps__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.2rem 2rem;
    }

    .home-how-steps-{{ section.id }} .home-how-steps__media {
      max-width: none;
      margin-top: 5.6rem;
    }

    .home-how-steps-{{ section.id }} .home-how-steps__stepbubble {
      display: inline-flex;
      position: absolute;
      left: 50%;
      top: 0;
      transform: translateX(-50%);
      z-index: 2;
    }

    .home-how-steps-{{ section.id }} .home-how-steps__stepline {
      position: absolute;
      top: 50%;
      display: block;
      height: 0;
      border-top: 0.2rem dotted rgba(29, 91, 215, 0.28);
      transform: translateY(-50%);
      z-index: 1;
    }

    .home-how-steps-{{ section.id }} .home-how-steps__stepline--left {
      left: 0;
      right: calc(50% + 1.8rem);
    }

    .home-how-steps-{{ section.id }} .home-how-steps__stepline--right {
      left: calc(50% + 1.8rem);
      right: 0;
    }
  }

  @media screen and (min-width: 990px) {
    .home-how-steps-{{ section.id }} .home-how-steps__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 2.4rem 2rem;
    }

    .home-how-steps-{{ section.id }} .home-how-steps__subtitle {
      margin-bottom: 4rem;
    }
  }
{%- endstyle -%}

<section class="home-how-steps-{{ section.id }} color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="home-how-steps__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="home-how-steps__heading {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
      <div class="home-how-steps__heading-accent" aria-hidden="true"></div>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="home-how-steps__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <ul class="home-how-steps__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="home-how-steps__item" {{ block.shopify_attributes }}>
          <div class="home-how-steps__stephead" aria-hidden="true">
            {%- if forloop.index > 1 -%}
              <span class="home-how-steps__stepline home-how-steps__stepline--left"></span>
            {%- endif -%}
            <span class="home-how-steps__stepbubble">{{ forloop.index }}</span>
            <span class="home-how-steps__stepline home-how-steps__stepline--right"></span>
          </div>
          <div class="home-how-steps__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 480
                | image_tag:
                  class: 'home-how-steps__image',
                  loading: 'lazy',
                  widths: '240, 360, 480',
                  sizes: '(min-width: 750px) 240px, calc(100vw - 6rem)',
                  alt: block.settings.title
              }}
            {%- else -%}
              <div class="home-how-steps__image-placeholder"></div>
            {%- endif -%}
            <span class="home-how-steps__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'search' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="6.5"></circle><path d="M16 16l5 5"></path></svg>
              {%- when 'map' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 8.5 12 4l8 4.5V19a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V8.5Z"></path><path d="M9 20v-6h6v6"></path><path d="M8 10h.01M12 10h.01M16 10h.01"></path></svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L12 17l-5.2 2.8 1-5.9-4.3-4.2 5.9-.9L12 3.5z"></path></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M16 3v4M8 3v4M3 10h18"></path></svg>
              {%- endcase -%}
            </span>
          </div>
          <h3 class="home-how-steps__title">{{ block.settings.title }}</h3>
          <div class="home-how-steps__title-accent" aria-hidden="true"></div>
          <p class="home-how-steps__text">{{ block.settings.text }}</p>
        </li>
      {%- endfor -%}
      <li class="home-how-steps__item">
        <div class="home-how-steps__stephead" aria-hidden="true">
          <span class="home-how-steps__stepline home-how-steps__stepline--left"></span>
          <span class="home-how-steps__stepbubble">4</span>
        </div>
        <div class="home-how-steps__media">
          {%- if section.settings.step_4_image != blank -%}
            {{
              section.settings.step_4_image
              | image_url: width: 480
              | image_tag:
                class: 'home-how-steps__image',
                loading: 'lazy',
                widths: '240, 360, 480',
                sizes: '(min-width: 750px) 240px, calc(100vw - 6rem)',
                alt: section.settings.step_4_title
            }}
          {%- else -%}
          {%- endif -%}
          <span class="home-how-steps__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L12 17l-5.2 2.8 1-5.9-4.3-4.2 5.9-.9L12 3.5z"></path></svg>
          </span>
        </div>
        <h3 class="home-how-steps__title">{{ section.settings.step_4_title }}</h3>
        <div class="home-how-steps__title-accent" aria-hidden="true"></div>
        <p class="home-how-steps__text">{{ section.settings.step_4_text }}</p>
      </li>
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Home How It Works",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "title", "label": "Title", "default": "Como funciona" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Reserva en pocos pasos y disfruta la mejor experiencia para tu coche." },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "image_picker", "id": "step_4_image", "label": "Step 4 image" },
    { "type": "text", "id": "step_4_title", "label": "Step 4 title", "default": "4. Vive la experiencia y valora el servicio" },
    { "type": "text", "id": "step_4_text", "label": "Step 4 text", "default": "Acude a tu cita y comparte tu opinion para ayudar a otros usuarios." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 20 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 20 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "search",
          "options": [
            { "value": "search", "label": "Search" },
            { "value": "map", "label": "Map" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "star", "label": "Star" }
          ]
        },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "1. Buscar servicio" },
        { "type": "text", "id": "text", "label": "Text", "default": "Busca y compara servicios para tu coche en segundos." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home How It Works",
      "blocks": [
        { "type": "step", "settings": { "icon": "search", "title": "1. Buscar servicio", "text": "Busca el servicio y compara talleres cerca de ti." } },
        { "type": "step", "settings": { "icon": "map", "title": "2. Elegir taller", "text": "Selecciona la mejor opcion por precio, ubicacion y valoraciones." } },
        { "type": "step", "settings": { "icon": "calendar", "title": "3. Reservar y relajarse", "text": "Reserva online y recibe la confirmacion de tu cita." } }
      ]
    }
  ]
}
{% endschema %}
