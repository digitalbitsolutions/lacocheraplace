{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lc-home-categories__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.8rem;
  }

  .lc-home-categories__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .lc-home-categories__card {
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 1.2rem;
    padding: 1.4rem 1.2rem;
    text-decoration: none;
    color: inherit;
    background: rgb(var(--color-background));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    min-height: 9.6rem;
  }

  .lc-home-categories__icon {
    color: #0f4cbd;
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .lc-home-categories__icon svg {
    width: 2.6rem;
    height: 2.6rem;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .lc-home-categories__name {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.3;
    text-align: center;
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .lc-home-categories__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .lc-home-categories__grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="lc-home-categories__head">
      <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
      {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </div>
    <div class="lc-home-categories__grid">
      {%- for block in section.blocks -%}
        {%- assign icon_key = block.settings.icon_key | default: '' -%}
        {%- assign legacy_hint = block.settings.icon_text | upcase -%}
        {%- assign category_name = block.settings.name | downcase -%}
        {%- assign looks_legacy = false -%}
        {%- if legacy_hint == 'L' or legacy_hint == 'D' or legacy_hint == 'M' or legacy_hint == 'N' or legacy_hint == 'B' or legacy_hint == 'F' or legacy_hint == 'DG' or legacy_hint == 'ITV' -%}
          {%- assign looks_legacy = true -%}
        {%- endif -%}

        {%- assign needs_legacy_map = false -%}
        {%- if icon_key == blank -%}
          {%- assign needs_legacy_map = true -%}
        {%- elsif icon_key == 'sparkles' and looks_legacy -%}
          {%- assign needs_legacy_map = true -%}
        {%- endif -%}

        {%- if needs_legacy_map -%}
          {%- assign category_name = block.settings.name | downcase -%}
          {%- if category_name contains 'limpieza' or legacy_hint == 'L' -%}
            {%- assign icon_key = 'sparkles' -%}
          {%- elsif category_name contains 'detailing' or legacy_hint == 'D' -%}
            {%- assign icon_key = 'spray' -%}
          {%- elsif category_name contains 'mecan' or legacy_hint == 'M' -%}
            {%- assign icon_key = 'wrench' -%}
          {%- elsif category_name contains 'neumatic' or legacy_hint == 'N' -%}
            {%- assign icon_key = 'tire' -%}
          {%- elsif category_name contains 'bateria' or legacy_hint == 'B' -%}
            {%- assign icon_key = 'battery' -%}
          {%- elsif category_name contains 'freno' or legacy_hint == 'F' -%}
            {%- assign icon_key = 'brake' -%}
          {%- elsif category_name contains 'diagnost' or legacy_hint == 'DG' -%}
            {%- assign icon_key = 'engine' -%}
          {%- elsif category_name contains 'itv' or legacy_hint == 'ITV' -%}
            {%- assign icon_key = 'checklist' -%}
          {%- elsif category_name contains 'ppf' or category_name contains 'vinilo' -%}
            {%- assign icon_key = 'shield' -%}
          {%- elsif category_name contains 'tintado' or category_name contains 'luna' or category_name contains 'parabrisas' -%}
            {%- assign icon_key = 'window' -%}
          {%- elsif category_name contains 'chapa' or category_name contains 'pintura' or category_name contains 'abolladura' -%}
            {%- assign icon_key = 'hammer' -%}
          {%- elsif category_name contains 'mantenimiento' -%}
            {%- assign icon_key = 'service' -%}
          {%- elsif category_name contains 'grua' or category_name contains 'asistencia' -%}
            {%- assign icon_key = 'tow' -%}
          {%- elsif category_name contains 'parking' or category_name contains 'aparcamiento' -%}
            {%- assign icon_key = 'parking' -%}
          {%- elsif category_name contains 'accesorio' or category_name contains 'producto' -%}
            {%- assign icon_key = 'kit' -%}
          {%- elsif category_name contains 'usados' or category_name contains 'liquidaciones' -%}
            {%- assign icon_key = 'tag' -%}
          {%- elsif category_name contains 'renta' or category_name contains 'herramientas' or category_name contains 'espacios' -%}
            {%- assign icon_key = 'toolbox' -%}
          {%- endif -%}
        {%- endif -%}
        <a
          class="lc-home-categories__card"
          {% if block.settings.link != blank %}
            href="{{ block.settings.link }}"
          {% else %}
            role="link"
            aria-disabled="true"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="lc-home-categories__icon" aria-hidden="true">
            {%- case icon_key -%}
              {%- when 'sparkles' -%}
                <svg viewBox="0 0 24 24"><path d="M12 3l1.8 4.2L18 9l-4.2 1.8L12 15l-1.8-4.2L6 9l4.2-1.8L12 3z"></path><path d="M5 14l1 2.4L8.4 17 6 18l-1 2.4L4 18l-2.4-1L4 16.4 5 14z"></path><path d="M18.5 13l.8 1.8 1.7.8-1.7.8-.8 1.8-.8-1.8-1.7-.8 1.7-.8.8-1.8z"></path></svg>
              {%- when 'spray' -%}
                <svg viewBox="0 0 24 24"><path d="M8 8h8v12H8z"></path><path d="M10 8V6h4v2"></path><path d="M13 4h3"></path><path d="M18 6h2M19 9h2M17 11h2"></path></svg>
              {%- when 'wrench' -%}
                <svg viewBox="0 0 24 24"><path d="M14.5 6.5a4 4 0 005 5l-8.7 8.7a2 2 0 11-2.8-2.8l8.7-8.7a4 4 0 01-2.2-2.2z"></path><path d="M4 4l5 5"></path></svg>
              {%- when 'tire' -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"></circle><circle cx="12" cy="12" r="3.2"></circle><path d="M12 4v3M20 12h-3M12 20v-3M4 12h3"></path></svg>
              {%- when 'battery' -%}
                <svg viewBox="0 0 24 24"><rect x="3" y="7" width="17" height="10" rx="2"></rect><path d="M20 10h1.5v4H20"></path><path d="M8 12h2M9 11v2M14 12h2"></path></svg>
              {%- when 'brake' -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="7"></circle><circle cx="12" cy="12" r="2.5"></circle><path d="M12 5v2M19 12h-2M12 19v-2M5 12h2"></path></svg>
              {%- when 'engine' -%}
                <svg viewBox="0 0 24 24"><path d="M4 10h11a3 3 0 013 3v2H9a5 5 0 01-5-5z"></path><path d="M15 10V7h3l2 2v4"></path><path d="M3 14h2"></path></svg>
              {%- when 'checklist' -%}
                <svg viewBox="0 0 24 24"><rect x="6" y="3" width="12" height="18" rx="2"></rect><path d="M9 8h6M9 12h6M9 16h6"></path><path d="M7 5h2"></path></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.5-3 7.8-7 10-4-2.2-7-5.5-7-10V6l7-3z"></path><path d="M9 12l2 2 4-4"></path></svg>
              {%- when 'window' -%}
                <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="2"></rect><path d="M3 10h18"></path><path d="M9 10v8"></path></svg>
              {%- when 'hammer' -%}
                <svg viewBox="0 0 24 24"><path d="M14 4l6 6"></path><path d="M12 6l6 6"></path><path d="M3 21l8-8"></path><path d="M11 13l-1.5-1.5"></path></svg>
              {%- when 'service' -%}
                <svg viewBox="0 0 24 24"><path d="M6 20v-6a6 6 0 1112 0v6"></path><path d="M9 20v-4h6v4"></path><path d="M12 5v3"></path></svg>
              {%- when 'tow' -%}
                <svg viewBox="0 0 24 24"><circle cx="7" cy="18" r="2"></circle><circle cx="17" cy="18" r="2"></circle><path d="M3 18h2l2-5h8l2 5h4"></path><path d="M14 13l3-4h3"></path></svg>
              {%- when 'parking' -%}
                <svg viewBox="0 0 24 24"><rect x="4" y="3" width="16" height="18" rx="2"></rect><path d="M9 17V7h4a3 3 0 110 6H9"></path></svg>
              {%- when 'kit' -%}
                <svg viewBox="0 0 24 24"><rect x="3" y="8" width="18" height="11" rx="2"></rect><path d="M9 8V6h6v2"></path><path d="M3 13h18"></path></svg>
              {%- when 'tag' -%}
                <svg viewBox="0 0 24 24"><path d="M3 12l9-9h7l2 2v7l-9 9L3 12z"></path><circle cx="16" cy="8" r="1"></circle></svg>
              {%- when 'toolbox' -%}
                <svg viewBox="0 0 24 24"><rect x="3" y="9" width="18" height="11" rx="2"></rect><path d="M9 9V6h6v3"></path><path d="M10 14h4"></path></svg>
              {%- else -%}
                {{ block.settings.icon_text }}
            {%- endcase -%}
          </span>
          <p class="lc-home-categories__name">{{ block.settings.name }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LCP Home Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Categorias principales" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Ver todas las categorías" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 20 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "select",
          "id": "icon_key",
          "label": "Icon",
          "default": "sparkles",
          "options": [
            { "value": "sparkles", "label": "Limpieza" },
            { "value": "spray", "label": "Detailing" },
            { "value": "wrench", "label": "Mecánica" },
            { "value": "tire", "label": "Neumáticos" },
            { "value": "battery", "label": "Baterías" },
            { "value": "brake", "label": "Frenos" },
            { "value": "engine", "label": "Diagnóstico" },
            { "value": "checklist", "label": "ITV" },
            { "value": "shield", "label": "PPF y vinilo" },
            { "value": "window", "label": "Tintado lunas/parabrisas" },
            { "value": "hammer", "label": "Chapa y pintura" },
            { "value": "service", "label": "Mantenimiento rápido" },
            { "value": "tow", "label": "Grúa y asistencia" },
            { "value": "parking", "label": "Parking" },
            { "value": "kit", "label": "Accesorios y productos" },
            { "value": "tag", "label": "Usados y liquidaciones" },
            { "value": "toolbox", "label": "Renta de espacios/herramientas" }
          ]
        },
        { "type": "text", "id": "icon_text", "label": "Legacy icon text fallback", "default": "A" },
        { "type": "text", "id": "name", "label": "Name", "default": "Categoria" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    { "name": "LCP Home Categories" }
  ]
}
{% endschema %}
