{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lc-home-categories__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.8rem;
  }

  .lc-home-categories__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .lc-home-categories__card {
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 1.2rem;
    padding: 1.4rem 1.2rem;
    text-decoration: none;
    color: inherit;
    background: rgb(var(--color-background));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    min-height: 9.6rem;
  }

  .lc-home-categories__icon {
    color: #0f4cbd;
    font-size: 2.4rem;
    line-height: 1;
    font-weight: 700;
  }

  .lc-home-categories__name {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.3;
    text-align: center;
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .lc-home-categories__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .lc-home-categories__grid {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="lc-home-categories__head">
      <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
      {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </div>
    <div class="lc-home-categories__grid">
      {%- for block in section.blocks -%}
        <a
          class="lc-home-categories__card"
          {% if block.settings.link != blank %}
            href="{{ block.settings.link }}"
          {% else %}
            role="link"
            aria-disabled="true"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="lc-home-categories__icon" aria-hidden="true">{{ block.settings.icon_text }}</span>
          <p class="lc-home-categories__name">{{ block.settings.name }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LCP Home Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Categorias principales" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Ver todas las categorias" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 20 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "icon_text", "label": "Icon text", "default": "A" },
        { "type": "text", "id": "name", "label": "Name", "default": "Categoria" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    { "name": "LCP Home Categories" }
  ]
}
{% endschema %}
