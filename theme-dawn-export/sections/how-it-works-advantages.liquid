{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.75);
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__panel {
    display: grid;
    gap: 0;
    border: 0.1rem solid rgba(18, 32, 68, 0.1);
    border-radius: 2rem;
    background: #fff;
    box-shadow: 0 1.2rem 3rem rgba(18, 32, 68, 0.06);
    overflow: hidden;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item {
    display: flex;
    align-items: flex-start;
    gap: 1.4rem;
    padding: 2rem 2.2rem;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__icon {
    flex: 0 0 auto;
    width: 4.6rem;
    height: 4.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #1d5bd7;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__icon svg {
    width: 3rem;
    height: 3rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__title {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 700;
    color: rgb(var(--color-foreground));
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__text {
    margin: 0.4rem 0 0;
    font-size: 1.25rem;
    line-height: 1.45;
    color: rgba(var(--color-foreground), 0.7);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item:nth-child(odd) {
      border-right: 0.1rem solid rgba(18, 32, 68, 0.08);
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item:nth-child(-n + 2) {
      border-bottom: 0.1rem solid rgba(18, 32, 68, 0.08);
    }
  }

  @media screen and (min-width: 990px) {
    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__panel {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item {
      min-height: 8.4rem;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item:nth-child(odd) {
      border-right: 0;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item:nth-child(-n + 2) {
      border-bottom: 0;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item:not(:last-child) {
      border-right: 0.1rem solid rgba(18, 32, 68, 0.08);
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <section class="how-it-works-advantages-{{ section.id }} page-width section-{{ section.id }}-padding">
    <div class="how-it-works-advantages__panel" role="list">
      <article class="how-it-works-advantages__item" role="listitem">
        <span class="how-it-works-advantages__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M12 3 5 6v6c0 4.4 2.9 7.9 7 9 4.1-1.1 7-4.6 7-9V6l-7-3Z"></path><path d="m9.2 12.4 1.8 1.8 3.9-4"></path></svg>
        </span>
        <div>
          <p class="how-it-works-advantages__title">Talleres verificados</p>
          <p class="how-it-works-advantages__text">Calidad y confianza garantizada.</p>
        </div>
      </article>

      <article class="how-it-works-advantages__item" role="listitem">
        <span class="how-it-works-advantages__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><rect x="6" y="10" width="12" height="10" rx="2"></rect><path d="M8 10V7a4 4 0 1 1 8 0v3"></path></svg>
        </span>
        <div>
          <p class="how-it-works-advantages__title">Reservas 100% online</p>
          <p class="how-it-works-advantages__text">Rapido, facil y seguro.</p>
        </div>
      </article>

      <article class="how-it-works-advantages__item" role="listitem">
        <span class="how-it-works-advantages__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="m12.5 3.5 7 7-7.8 7.8L4 10.6l7.8-7.1h.7Z"></path><circle cx="15.5" cy="8.5" r="1"></circle></svg>
        </span>
        <div>
          <p class="how-it-works-advantages__title">Precios transparentes</p>
          <p class="how-it-works-advantages__text">Sin sorpresas ni costos ocultos.</p>
        </div>
      </article>

      <article class="how-it-works-advantages__item" role="listitem">
        <span class="how-it-works-advantages__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M6 17.5c-1.7 0-3-1.3-3-3v-5c0-1.7 1.3-3 3-3h12c1.7 0 3 1.3 3 3v5c0 1.7-1.3 3-3 3h-5l-4.5 3v-3H6Z"></path><path d="M8 11.5h.01M12 11.5h.01M16 11.5h.01"></path></svg>
        </span>
        <div>
          <p class="how-it-works-advantages__title">Opiniones reales</p>
          <p class="how-it-works-advantages__text">De clientes como tu.</p>
        </div>
      </article>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "How It Works Advantages",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "How It Works Advantages"
    }
  ]
}
{% endschema %}
