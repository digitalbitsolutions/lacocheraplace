{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.75);
  }

  .how-it-works-advantages-{{ section.id }} {
    position: relative;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__panel {
    position: relative;
    display: grid;
    gap: 3rem;
    padding: 3rem 2.4rem;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 3rem;
    background:
      radial-gradient(circle at top right, rgba(43, 91, 211, 0.1), transparent 32%),
      radial-gradient(circle at bottom left, rgba(18, 140, 126, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(var(--color-background), 0.98), rgba(var(--color-foreground), 0.02));
    box-shadow: 0 2rem 5rem rgba(var(--color-foreground), 0.08);
    overflow: hidden;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__intro {
    position: relative;
    z-index: 1;
    max-width: 58rem;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__eyebrow {
    margin: 0 0 1rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.65);
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__heading {
    margin: 0;
    font-size: clamp(2.8rem, 3.5vw, 4.2rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__lead {
    margin: 1.4rem 0 0;
    max-width: 52rem;
    font-size: 1.7rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.4rem;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    padding: 1.6rem 1.8rem;
    border-radius: 1.8rem;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    background: rgba(var(--color-background), 0.88);
    backdrop-filter: blur(6px);
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__check {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 999px;
    background: rgba(43, 91, 211, 0.12);
    font-size: 1.6rem;
    line-height: 1;
  }

  .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__text {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.55;
    color: rgb(var(--color-foreground));
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__panel {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      align-items: start;
      gap: 4rem;
      padding: 4.4rem;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item:last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 749px) {
    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__panel {
      padding: 2.4rem 2rem;
      border-radius: 2.4rem;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__lead {
      font-size: 1.5rem;
    }

    .how-it-works-advantages-{{ section.id }} .how-it-works-advantages__item {
      padding: 1.5rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <section class="how-it-works-advantages-{{ section.id }} page-width section-{{ section.id }}-padding">
    <div class="how-it-works-advantages__panel">
      <div class="how-it-works-advantages__intro">
        <p class="how-it-works-advantages__eyebrow">Por que elegirnos</p>
        <h2 class="how-it-works-advantages__heading">
          Ventajas de usar La Cochera MarketPlace
          <span aria-hidden="true">&#128663;&#127949;</span>
        </h2>
        <p class="how-it-works-advantages__lead">
          Una experiencia simple, confiable y segura para encontrar, comparar y reservar servicios automotrices desde un solo lugar.
        </p>
      </div>

      <div class="how-it-works-advantages__grid" role="list">
        <article class="how-it-works-advantages__item" role="listitem">
          <span class="how-it-works-advantages__check" aria-hidden="true">&#10004;&#65039;</span>
          <p class="how-it-works-advantages__text">Talleres verificados y profesionales</p>
        </article>
        <article class="how-it-works-advantages__item" role="listitem">
          <span class="how-it-works-advantages__check" aria-hidden="true">&#10004;&#65039;</span>
          <p class="how-it-works-advantages__text">Comparacion de servicios en un solo lugar</p>
        </article>
        <article class="how-it-works-advantages__item" role="listitem">
          <span class="how-it-works-advantages__check" aria-hidden="true">&#10004;&#65039;</span>
          <p class="how-it-works-advantages__text">Pagos seguros online</p>
        </article>
        <article class="how-it-works-advantages__item" role="listitem">
          <span class="how-it-works-advantages__check" aria-hidden="true">&#10004;&#65039;</span>
          <p class="how-it-works-advantages__text">Opiniones reales de clientes</p>
        </article>
        <article class="how-it-works-advantages__item" role="listitem">
          <span class="how-it-works-advantages__check" aria-hidden="true">&#10004;&#65039;</span>
          <p class="how-it-works-advantages__text">Servicios automotrices cerca de ti</p>
        </article>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "How It Works Advantages",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "How It Works Advantages"
    }
  ]
}
{% endschema %}
