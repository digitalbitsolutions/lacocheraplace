    "multicolumn_aHED4U": {
      "type": "multicolumn",
      "blocks": {
        "column_lavado": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gemini_Generated_Image_r65atgr65atgr65a.png",
            "title": "Lavado de coches",
            "text": "<p>Limpieza interior y exterior para mantener tu coche siempre impecable. Desde lavados rapidos hasta servicios completos con acabado profesional.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/lavado"
          }
        },
        "column_detailing": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gemini_Generated_Image_xexmmbxexmmbxexm.png",
            "title": "Pulido y detailing de coches",
            "text": "<p>Restauracion estetica y cuidado profundo del vehiculo. Incluye pulido, correccion de pintura y tratamientos ceramicos para proteger y realzar el brillo.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/detailing"
          }
        },
        "column_neumaticos": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/cambio-neumaticos.webp",
            "custom_asset_image": "cambio-neumaticos.webp",
            "title": "Cambio de neumaticos y llantas",
            "text": "<p>Sustitucion y mantenimiento de neumaticos para una conduccion segura. Servicios de alineacion, balanceo y reparacion de pinchazos.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/neumaticos-y-llantas"
          }
        },
        "column_ppf": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/PPF.webp",
            "custom_asset_image": "home-ppf.webp",
            "title": "PPF y vinilo para coches (Wrap)",
            "text": "<p>Proteccion y personalizacion de la carroceria con laminas PPF o vinilo. Evita danos en la pintura o cambia el estilo de tu coche.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/ppf-wrap-tintado-lunas"
          }
        },
        "column_tintado": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/tintado-de-lunas.webp",
            "custom_asset_image": "home-tintado-lunas.webp",
            "title": "Tintado de lunas y parabrisas",
            "text": "<p>Tintado de cristales para mayor privacidad, confort y proteccion solar. Incluye reparacion y sustitucion de lunas o parabrisas.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/ppf-wrap-tintado-lunas"
          }
        },
        "column_chapa": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gemini_Generated_Image_mu6yc9mu6yc9mu6y.png",
            "title": "Chapa, pintura y abolladuras",
            "text": "<p>Reparacion de golpes, aranazos y danos en la carroceria. Eliminacion de abolladuras sin pintar y acabados profesionales.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/chapa-y-pintura"
          }
        },
        "column_mantenimiento": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gemini_Generated_Image_eoqb8xeoqb8xeoqb.png",
            "title": "Mantenimiento rapido de coches",
            "text": "<p>Servicios esenciales para el buen funcionamiento del vehiculo, como cambio de aceite, filtros y revisiones basicas.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/mantenimiento-ligero"
          }
        },
        "column_grua": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gemini_Generated_Image_w62hvw62hvw62hvw.png",
            "title": "Grua y asistencia en carretera",
            "text": "<p>Asistencia inmediata ante averias o emergencias. Servicio de grua, arranque de bateria y ayuda en carretera cuando lo necesites.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/grua-y-auxlio-mecanico"
          }
        },
        "column_parking": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/parking-benidorm-1200x731.jpg",
            "title": "Parking y aparcamiento",
            "text": "<p>Opciones de aparcamiento seguro por horas, dias o larga estancia, ideales para ciudad o viajes.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/parking"
          }
        },
        "column_productos": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gemini_Generated_Image_x0vc4ax0vc4ax0vc.png",
            "title": "Accesorios y productos para coche",
            "text": "<p>Accesorios y productos para cuidar y mejorar tu coche, desde lo esencial hasta soluciones profesionales.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/productos-y-accesorios-para-el-cuidado-automotriz"
          }
        },
        "column_usados_liquidaciones": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gemini_Generated_Image_x0vc4ax0vc4ax0vc.png",
            "title": "Productos usados y liquidaciones",
            "text": "<p>Encuentra oportunidades de vehiculos usados revisados y servicios asociados de liquidacion con proveedores en Barcelona.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/productos-usados-y-liquidaciones"
          }
        },
        "column_renta_espacios_herramientas": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/parking-benidorm-1200x731.jpg",
            "title": "Renta de Espacios y Herramientas para Automocion",
            "text": "<p>Reserva boxes y herramientas para trabajos de automocion por horas o jornada completa, con soporte profesional.</p>",
            "link_label": "Reservar ahora",
            "link": "shopify://collections/renta-de-espacios-y-herramientas-para-automocion"
          }
        }
      },
